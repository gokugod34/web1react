<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('./partials/organisms/header') %>
    <%- include('./partials/molecules/categoryMenu') %>

    <main class="category-page-main">
        <section class="product-list-section" aria-labelledby="category-heading">
            <h1 id="category-heading" style="text-align: center; margin-bottom: 2rem; font-size: 2.5rem; text-transform: capitalize;">Categoría: <%= categoryName %></h1>
            
            <% if (products && products.length > 0) { %>
                <div class="products-grid">
                    <% products.forEach(p => { %>
                        <%- include('./partials/card', { producto: p }) %>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <p style="text-align: center; color: var(--text-muted); font-size: 1.2rem; margin: 3rem 0;">No se encontraron productos en la categoría <%= categoryName %></p>
                </div>
            <% } %>
        </section>
    </main>

    <%- include('./partials/molecules/categoryMenu') %>
    <%- include('./partials/organisms/footer') %>

    <script src="/js/main.js"></script>
</body>
</html>
