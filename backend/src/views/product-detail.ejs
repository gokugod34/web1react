<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('./partials/organisms/header') %>
    <%- include('./partials/molecules/categoryMenu') %>

    <main class="product-page-main">
        <section class="product-details-section" aria-label="Detalles del producto">
            <div class="product-gallery">
                <img src="<%= product.image ? product.image : '/images/logo.png' %>" alt="<%= product.name %>" class="main-product-image">
            </div>
            <div class="product-info">
                <h1 class="product-title">
                    <%= product.name %>
                    <% if (product.stock === 0) { %>
                        <span class="no-stock-badge-detail" style="font-size: 0.9rem; background: linear-gradient(135deg, #ef4444, #b91c1c); color: white; padding: 0.25rem 0.75rem; border-radius: 9999px; margin-left: 1rem; vertical-align: middle; display: inline-block; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Sin stock</span>
                    <% } %>
                </h1>
                <p class="product-category" style="color: var(--text-muted); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;"><%= product.category %></p>
                <p class="product-price"><%= product.price %></p>
                <div class="product-description">
                    <h3>Descripción</h3>
                    <p><%= product.description %></p>
                </div>
                <div class="product-actions">
                    <form action="/cart/add" method="POST">
                        <input type="hidden" name="productId" value="<%= product.id %>">
                        <button type="submit" class="btn btn-add-to-cart" <%= product.stock === 0 ? 'disabled' : '' %>>
                            <% if (product.stock === 0) { %>
                                <i class="bi bi-cart-x"></i> Sin stock
                            <% } else { %>
                                <i class="bi bi-cart-plus"></i> Añadir al carrito
                            <% } %>
                        </button>
                    </form>
                </div>
            </div>
        </section>

        <section class="product-list-section related-products" aria-labelledby="related-heading">
            <h2 id="related-heading">Productos Relacionados</h2>
            
            <% if (relatedProducts && relatedProducts.length > 0) { %>
                <div class="products-grid">
                    <% relatedProducts.forEach(p => { %>
                        <%- include('./partials/card', { producto: p }) %>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <p style="text-align: center; color: var(--text-muted); font-size: 1.1rem; margin: 2rem 0;">No hay productos relacionados disponibles</p>
                </div>
            <% } %>
        </section>
    </main>

    <%- include('./partials/molecules/categoryMenu') %>
    <%- include('./partials/organisms/footer') %>

    <script src="/js/main.js"></script>
</body>
</html>
