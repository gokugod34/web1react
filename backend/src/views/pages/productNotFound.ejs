<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/organisms/header') %>
    <%- include('../partials/molecules/categoryMenu') %>

    <main class="not-found-main">
        <section class="error-section" aria-label="Página no encontrada">
            <div class="error-content">
                <h1>Oops! Producto no encontrado</h1>
                <p>Parece que el producto que estás buscando no existe o ya no está disponible.</p>
                <i class="bi bi-emoji-frown error-icon"></i><br>
                <a href="/" class="btn btn-back">Volver al inicio</a>
            </div>
        </section>

        <% if (suggestedProducts && suggestedProducts.length > 0) { %>
        <section class="product-list-section suggested-products" aria-labelledby="suggested-heading">
            <h2 id="suggested-heading">Te podría interesar</h2>
            <div class="products-grid">
                <% suggestedProducts.forEach(p => { %>
                    <article class="product-card" onclick="window.location.href='/product/<%= p.id %>'">
                        <div class="card-img-container">
                            <img src="<%= p.image %>" alt="<%= p.name %>">
                        </div>
                        <div class="card-info">
                            <h3><%= p.name %></h3>
                            <p class="price"><%= p.price %></p>
                        </div>
                    </article>
                <% }) %>
            </div>
        </section>
        <% } %>
    </main>

    <%- include('../partials/organisms/footer') %>

    <script src="/js/main.js"></script>
</body>
</html>
