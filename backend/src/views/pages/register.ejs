<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Vimet Store</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/organisms/header') %>
    <%- include('../partials/molecules/categoryMenu') %>

    <main class="auth-page-main">
        <section class="auth-section" aria-label="Formulario de registro">
            <div class="auth-header">
                <h2>Crear Cuenta</h2>
                <p>Únete a Vimet Store hoy mismo</p>
            </div>
            
            <form action="/register" method="POST" class="auth-form">
                <div class="form-group">
                    <label for="firstName">Nombre</label>
                    <input type="text" id="firstName" name="firstName" placeholder="Ej: Juan" value="<%= locals.oldData ? oldData.firstName : '' %>" class="<%= locals.errors && errors.firstName ? 'is-invalid' : '' %>">
                    <% if (locals.errors && errors.firstName) { %>
                        <p class="error-message"><%= errors.firstName %></p>
                    <% } %>
                </div>
                <div class="form-group">
                    <label for="lastName">Apellido</label>
                    <input type="text" id="lastName" name="lastName" placeholder="Ej: Pérez" value="<%= locals.oldData ? oldData.lastName : '' %>" class="<%= locals.errors && errors.lastName ? 'is-invalid' : '' %>">
                    <% if (locals.errors && errors.lastName) { %>
                        <p class="error-message"><%= errors.lastName %></p>
                    <% } %>
                </div>
                <div class="form-group">
                    <label for="email">Correo Electrónico</label>
                    <input type="email" id="email" name="email" placeholder="ejemplo@correo.com" value="<%= locals.oldData ? oldData.email : '' %>" class="<%= locals.errors && errors.email ? 'is-invalid' : '' %>">
                    <% if (locals.errors && errors.email) { %>
                        <p class="error-message"><%= errors.email %></p>
                    <% } %>
                </div>
                <div class="form-group">
                    <label for="password">Contraseña</label>
                    <input type="password" id="password" name="password" placeholder="••••••••" class="<%= locals.errors && errors.password ? 'is-invalid' : '' %>">
                    <% if (locals.errors && errors.password) { %>
                        <p class="error-message"><%= errors.password %></p>
                    <% } %>
                </div>
                <button type="submit" class="btn btn-primary btn-block">Registrarme</button>
            </form>
            
            <div class="auth-divider">
                <span>o</span>
            </div>
            
            <div class="auth-links">
                <p>¿Ya tienes una cuenta?</p>
                <a href="/login" class="btn btn-outline btn-block">Iniciar sesión</a>
            </div>
        </section>
    </main>

    <%- include('../partials/organisms/footer') %>
</body>
</html>