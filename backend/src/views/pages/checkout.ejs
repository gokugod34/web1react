<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/organisms/header') %>

    <main class="checkout-temporal" style="text-align: center; padding: 5rem 2rem; min-height: 50vh; display: flex; flex-direction: column; justify-content: center; align-items: center;">
        <i class="bi bi-tools" style="font-size: 4rem; color: var(--primary-color); margin-bottom: 1rem;"></i>
        <h2 style="font-size: 2rem; margin-bottom: 1rem;">Checkout Temporal</h2>
        <p style="font-size: 1.25rem; color: var(--text-muted); margin-bottom: 2rem;">Checkout disponible en el próximo sprint</p>
        <div style="display: flex; gap: 1rem; justify-content: center;">
            <a href="/cart" class="btn btn-outline"><i class="bi bi-cart"></i> Volver al Carrito</a>
            <a href="/" class="btn btn-primary"><i class="bi bi-house"></i> Volver al Inicio</a>
        </div>
    </main>

    <%- include('../partials/organisms/footer') %>
</body>
</html>
